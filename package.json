{
  "name": "fwd-bharat-marketdesk-nse-bse",
  "version": "0.1.11",
  "private": true,
  "author": "Dhiraj Jha",
  "description": "FWD Bharat MarketDesk read-only NSE/BSE market-data desktop shell.",
  "license": "MIT",
  "homepage": "https://github.com/Flywithdhiraj/fwd-bharat-marketdesk#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Flywithdhiraj/fwd-bharat-marketdesk.git"
  },
  "bugs": {
    "url": "https://github.com/Flywithdhiraj/fwd-bharat-marketdesk/issues"
  },
  "keywords": [
    "electron",
    "dhan",
    "nse",
    "bse",
    "market-data",
    "trading-tools",
    "options-analytics",
    "india-markets",
    "read-only",
    "desktop"
  ],
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron .",
    "build:renderer": "node scripts/sync-renderer-bundles.js",
    "check:renderer": "node scripts/sync-renderer-bundles.js --check",
    "check": "npm run check:renderer && powershell -NoProfile -ExecutionPolicy Bypass -File scripts/check-js.ps1 && npm run check:dhan-data && npm run check:equity-history-backfill && npm run check:options-hub && npm run check:fno-carry && npm run check:fno-market-charts && npm run check:commodities && npm run check:commodity-spread-decision && npm run check:commodity-spread-research && npm run check:manual-safety && npm run check:brain && npm run check:benchmark && npm run check:strategy-lab-safety && npm run check:radar && npm run check:reversal && npm run check:darvas && npm run check:pullback && npm run check:wizard && npm run check:stage && npm run check:visual && npm run check:scan-context && npm run check:chart-local-first && npm run check:chart-drag && npm run check:detach-startup",
    "check:visual": "node scripts/visual-smoke.js",
    "check:wizard": "node scripts/wizard-strategy-smoke.js",
    "check:stage": "node scripts/stage-strategy-smoke.js",
    "check:manual-safety": "node scripts/dhan-manual-safety-smoke.js",
    "check:options-hub": "node scripts/options-hub-smoke.js",
    "check:fno-carry": "node scripts/fno-carry-smoke.js",
    "check:fno-market-charts": "node scripts/fno-market-charts-smoke.js",
    "check:commodities": "node scripts/commodities-smoke.js",
    "check:commodity-spread-decision": "node scripts/commodity-spread-decision-smoke.js",
    "check:commodity-spread-research": "node scripts/commodity-spread-research-smoke.js",
    "research:mcx:download": "electron scripts/mcx-bhavcopy-download.js",
    "research:commodity": "node scripts/commodity-spread-research.js",
    "check:radar": "node scripts/radar-strategy-smoke.js",
    "check:strategy-lab-safety": "node scripts/strategy-lab-safety-smoke.js",
    "check:benchmark": "node scripts/dhan-benchmark-smoke.js",
    "check:reversal": "node scripts/reversal-strategy-smoke.js",
    "check:darvas": "node scripts/darvas-strategy-smoke.js",
    "check:pullback": "node scripts/pullback-strategy-smoke.js",
    "check:scan-context": "node scripts/shared-scan-context-smoke.js",
    "check:chart-local-first": "node scripts/chart-local-first-smoke.js",
    "check:chart-drag": "node scripts/chart-drag-order-smoke.js",
    "check:detach-startup": "node scripts/detached-chart-startup-smoke.js",
    "check:brain": "node scripts/action-brain-smoke.js",
    "check:dhan-data": "node scripts/dhan-data-service-smoke.js",
    "check:equity-history-backfill": "node scripts/equity-history-backfill-smoke.js",
    "test:live-socket": "electron scripts/dhan-live-socket-test.js",
    "test:live-commodity": "electron scripts/commodity-live-snapshot-test.js",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "build": {
    "appId": "com.fwd.bharatmarketdesk.nsebse",
    "productName": "FWD Bharat MarketDesk",
    "copyright": "Copyright (c) 2026 Dhiraj Jha",
    "afterPack": "scripts/after-pack-branding.js",
    "directories": {
      "output": "release"
    },
    "files": [
      "src/**/*",
      "!src/renderer/scripts/popup/parts/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "executableName": "FWD Bharat MarketDesk",
      "icon": "src/renderer/icons/fwd-bharat-marketdesk.ico",
      "signAndEditExecutable": false,
      "legalTrademarks": "FWD Bharat MarketDesk"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "include": "build/installer.nsh"
    }
  },
  "devDependencies": {
    "electron": "^41.3.0",
    "electron-builder": "^26.0.0"
  },
  "dependencies": {
    "lightweight-charts": "^5.2.0",
    "qrcode": "^1.5.4"
  },
  "optionalDependencies": {
    "argon2": "^0.44.0"
  }
}
