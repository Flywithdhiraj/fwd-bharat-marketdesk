 const enabled = v16IsLiveAccountSyncEnabled();
 document.querySelectorAll('[data-live-account-sync-toggle]').forEach(button => {
 button.textContent = enabled ? 'Auto Sync On' : 'Auto Sync Off';
 button.classList.toggle('warn', !enabled);
 button.title = enabled
 ? 'Disable automatic live Delta account refresh for Analytics and Positions'
 : 'Enable automatic live Delta account refresh for Analytics and Positions';
 });
}

