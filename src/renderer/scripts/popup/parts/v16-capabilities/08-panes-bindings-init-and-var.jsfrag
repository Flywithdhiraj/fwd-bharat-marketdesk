globalThis.v16BuildManageAnalyticsModel = v16BuildManageAnalyticsModel;
globalThis.v16GetManageHistoryBundle = v16GetManageHistoryBundle;
globalThis.v16EnsureLiveManageHistory = v16EnsureLiveManageHistory;
globalThis.initV16CapabilityUpgrade = initV16CapabilityUpgrade;
globalThis.v16IsLiveAccountSyncEnabled = v16IsLiveAccountSyncEnabled;
globalThis.v16IsLiveAnalyticsAutoRefreshEnabled = v16IsLiveAnalyticsAutoRefreshEnabled;
globalThis.v16SyncLiveAccountSyncButtons = v16SyncLiveAccountSyncButtons;
globalThis.v16SyncLiveAnalyticsAutoRefreshButtons = v16SyncLiveAnalyticsAutoRefreshButtons;
