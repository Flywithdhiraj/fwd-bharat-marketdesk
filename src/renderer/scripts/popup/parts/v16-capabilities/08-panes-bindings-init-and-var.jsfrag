// Positions, funds, orders, settings bindings, init and VAR dashboard
 statusClass: `live-account-status ${activeRateLimit ? 'warn' : (metrics.todayPnl >= 0 ? 'good' : 'bad')}`,
 };
}

// Positions, orders, settings bindings, init and VAR dashboard
async function renderV16PositionsPane(preloaded = null, forceRefresh = false) {
 const pane = document.getElementById('pane-positions');
 if (!pane) return;
 v16ApplyTradingUiPrefs();
 v16LiveAccountView.positionNotificationsEnabled = localStorage.getItem('v16PositionNotificationsEnabled') === '1';
 const statusEl = document.getElementById('liveAccountStatus');
 const context = await v16LoadLiveAccountPaneContext(preloaded, forceRefresh);
 if (statusEl) {
 statusEl.textContent = context.statusText;
 statusEl.title = context.statusDetail || context.statusText || '';
 statusEl.className = context.statusClass;
 }
 if (!context.snapshot || !context.metrics) {
 v16UpdateRateLimitBanner(null);
 return;
 }
 v16UpdateRateLimitBanner(context.activeRateLimit, 'Positions');
 const { snapshot, metrics, history } = context;
 await v16RenderSystemHealthStrip('livePositionsHealthBar', { metrics, snapshot });
 v16RenderSessionCards(metrics);
 v16RenderPositions(metrics);
 const positionsSearchInput = document.getElementById('positionsSearchInput');
 if (positionsSearchInput) positionsSearchInput.value = String(v16LiveAccountView.positionsSearch || '');
 v16RenderJournal(metrics.trades);
 const todayHistory = history.filter(point => Number(point.ts || 0) >= v16StartOfToday());
 v16RenderEquityChart(todayHistory, metrics.todayTrades);
 const liveEquityMetaEl = document.getElementById('liveEquityMeta');
 if (liveEquityMetaEl) {
 liveEquityMetaEl.textContent = `${todayHistory.length} points today | Hover to inspect P&L and trade events | ${v16MarketDataSourceLabel(snapshot?.feedSource || 'rest')} | updated ${v16FormatFeedAge(snapshot?.fetchedAt || 0)}.`;
 }
 await renderV16RiskManageBoard();
}

function v16TradingUiPrefs() {
 return {
 compactDensity: localStorage.getItem('v16TradingCompactDensity') === '1',
 compactEquity: localStorage.getItem('v16TradingCompactEquity') === '1',
 };
}

function v16ApplyTradingUiPrefs() {
 const prefs = v16TradingUiPrefs();
 ['pane-positions', 'pane-orders', 'pane-funds'].forEach(id => {
 const pane = document.getElementById(id);
 if (pane) pane.classList.toggle('trading-density-compact', prefs.compactDensity);
 });
 document.querySelectorAll('[data-trading-density-toggle]').forEach(button => {
 button.classList.toggle('active', prefs.compactDensity);
 button.textContent = prefs.compactDensity ? 'Comfort density' : 'Compact density';
 });
 document.querySelectorAll('[data-equity-density-toggle]').forEach(button => {
 button.classList.toggle('active', prefs.compactEquity);
 button.textContent = prefs.compactEquity ? 'Full curve' : 'Compact curve';
 });
 document.querySelectorAll('.live-equity-card').forEach(card => {
 card.classList.toggle('is-compact', prefs.compactEquity);
 });
}

function v16RenderFunds(metrics = {}) {
 const hero = document.getElementById('liveFundsHero');
 const balanceGrid = document.getElementById('liveFundsBalanceGrid');
 const balanceMeta = document.getElementById('liveFundsBalanceMeta');
 const capacityGrid = document.getElementById('liveFundsCapacityGrid');
 const capacityMeta = document.getElementById('liveFundsCapacityMeta');
 const capacityMeter = document.getElementById('liveFundsCapacityMeter');
 const reconcileLine = document.getElementById('liveFundsReconcileLine');
 const ledgerList = document.getElementById('liveFundsLedgerList');
 const ledgerMeta = document.getElementById('liveFundsLedgerMeta');
 if (!hero || !balanceGrid || !capacityGrid || !ledgerList) return;
 v16LiveAccountView.lastFundsMetrics = metrics;
 v16ApplyTradingUiPrefs();
 const balances = Array.isArray(metrics.balances) ? metrics.balances : [];
 const positions = Array.isArray(metrics.positions) ? metrics.positions : [];
 const walletBalance = Number(metrics.walletBalance || 0);
 const walletAvailable = Number(metrics.walletAvailable || 0);
 const marginUsed = positions.reduce((sum, position) => sum + Number(position.margin || 0), 0);
 const reserved = Math.max(0, walletBalance - walletAvailable - marginUsed);
 const utilization = walletBalance > 0 ? (marginUsed / walletBalance) * 100 : 0;
 const exposure = Number(metrics.exposure?.notional || positions.reduce((sum, position) => sum + Math.abs(Number(position.notionalValue || 0)), 0));
 const equity = walletBalance + Number(metrics.unrealized || 0);
 const fmtMoney = value => `${metrics.walletSymbol || 'USD'} ${v16FmtNumber(Number(value || 0), 2)}`;
 const showZeroBalances = document.getElementById('liveFundsShowZero')?.checked === true;
 const visibleBalances = showZeroBalances ? balances : balances.filter(item => {
 const bal = Math.abs(Number(item.balance || 0));
 const avail = Math.abs(Number(item.available || 0));
 return bal > 0.00000001 || avail > 0.00000001;
 });
 hero.innerHTML = [
 { label: 'Wallet', value: fmtMoney(walletBalance), meta: `${visibleBalances.length}/${balances.length || 0} visible balance line${balances.length === 1 ? '' : 's'}`, tone: 'info' },
 { label: 'Available', value: fmtMoney(walletAvailable), meta: 'Free balance / available margin', tone: walletAvailable > 0 ? 'good' : 'warn' },
 { label: 'Margin used', value: fmtMoney(marginUsed), meta: `${v16FmtNumber(utilization, 1)}% wallet utilization`, tone: utilization >= 80 ? 'bad' : utilization >= 50 ? 'warn' : 'good' },
 { label: 'Net Today', value: v16FormatSignedCash(metrics.todayPnl || 0), meta: `Equity ${fmtMoney(equity)}`, tone: Number(metrics.todayPnl || 0) >= 0 ? 'good' : 'bad' },
 ].map(card => `<div class="funds-hero-card funds-hero-card--${v16Esc(card.tone)}"><span>${v16Esc(card.label)}</span><strong class="${v16Esc(card.tone)}">${v16Esc(card.value)}</strong><small>${v16Esc(card.meta)}</small></div>`).join('');
 if (balanceMeta) balanceMeta.textContent = `${visibleBalances.length} visible of ${balances.length || 0} wallet line${balances.length === 1 ? '' : 's'} | primary ${v16Esc(metrics.walletSymbol || 'USD')}`;
 balanceGrid.innerHTML = visibleBalances.length
 ? visibleBalances.map(item => {
 const bal = Number(item.balance || 0);
 const avail = Number(item.available || 0);
 const locked = Math.max(0, bal - avail);
 const pct = bal > 0 ? (avail / bal) * 100 : 0;
 return `<div class="funds-balance-row">
 <div><strong>${v16Esc(item.symbol || 'USD')}</strong><span>Balance ${v16FmtNumber(bal, 4)}</span></div>
 <div><strong>${v16FmtNumber(avail, 4)}</strong><span>Available</span></div>
 <div><strong>${v16FmtNumber(locked, 4)}</strong><span>Locked</span></div>
 <div class="funds-meter"><span style="width:${Math.max(0, Math.min(100, pct))}%"></span></div>
 </div>`;
 }).join('')
 : `<div class="empty"><div class="ei">--</div><div class="eh">${balances.length ? 'Zero balances hidden' : 'No balance returned'}</div><div class="es">${balances.length ? 'Enable Show zero balances to inspect empty assets.' : 'Refresh after API credentials are saved.'}</div></div>`;
 if (capacityMeta) capacityMeta.textContent = `${positions.length} position${positions.length === 1 ? '' : 's'} | exposure ${fmtMoney(exposure)} | reserved estimate ${fmtMoney(reserved)}`;
 if (capacityMeter) {
 const usedPct = Math.max(0, Math.min(100, utilization));
 const exposurePct = walletBalance > 0 ? Math.max(0, Math.min(100, (exposure / walletBalance) * 100)) : 0;
 capacityMeter.innerHTML = `
 <div class="funds-meter-row"><span>Margin use</span><strong>${v16FmtNumber(usedPct, 1)}%</strong></div>
 <div class="funds-capacity-track"><span class="${usedPct >= 80 ? 'bad' : usedPct >= 50 ? 'warn' : 'good'}" style="width:${usedPct}%"></span></div>
 <div class="funds-meter-row"><span>Open notional vs wallet</span><strong>${walletBalance > 0 ? `${v16FmtNumber(exposurePct, 1)}%` : '--'}</strong></div>
 <div class="funds-capacity-track exposure"><span style="width:${exposurePct}%"></span></div>`;
 }
 if (reconcileLine) {
 reconcileLine.innerHTML = `<strong>Reconcile</strong><span>Wallet equity = ${fmtMoney(walletBalance)} wallet + ${v16FmtSigned(Number(metrics.unrealized || 0))} unrealized = ${fmtMoney(equity)}</span>`;
 }
 capacityGrid.innerHTML = [
 ['Wallet equity', fmtMoney(equity), 'Wallet plus unrealized P&L'],
 ['Available funds', fmtMoney(walletAvailable), 'Ready for new margin or withdrawal'],
 ['Position margin', fmtMoney(marginUsed), `${positions.length} open position${positions.length === 1 ? '' : 's'}`],
 ['Reserved / locked', fmtMoney(reserved), 'Balance not currently free'],
 ['Open notional', fmtMoney(exposure), 'Absolute live exposure'],
 ['Unrealized P&L', v16FmtSigned(metrics.unrealized || 0), 'Current open P&L'],
 ['Closed today', v16FmtSigned(metrics.realizedToday || 0), metrics.realizedJournalSource || 'Realized source'],
 ['Fees + funding', v16FmtSigned(-Math.abs(Number(metrics.feesPaidToday || 0)) + Number(metrics.feeCreditsToday || 0) + Number(metrics.fundingToday || 0)), 'Today fee/funding impact'],
 ].map(([label, value, meta]) => `<div class="funds-capacity-item"><span>${v16Esc(label)}</span><strong>${v16Esc(value)}</strong><small>${v16Esc(meta)}</small></div>`).join('');
 const ledgerFilter = String(document.getElementById('liveFundsLedgerFilter')?.value || 'all').toLowerCase();
 const allRecent = (Array.isArray(metrics.walletTransactions) ? metrics.walletTransactions : []);
 const filteredRecent = allRecent.filter(item => {
 if (ledgerFilter === 'all') return true;
 const role = v16WalletTransactionRole(item).toLowerCase();
 if (ledgerFilter === 'transfer') return /deposit|withdraw|transfer/i.test(role);
 return role.includes(ledgerFilter);
 });
 const recent = filteredRecent.slice(0, 12);
 if (ledgerMeta) ledgerMeta.textContent = recent.length ? `${recent.length} latest ${ledgerFilter === 'all' ? 'wallet' : ledgerFilter} transaction${recent.length === 1 ? '' : 's'}` : 'No wallet transactions returned.';
 ledgerList.innerHTML = recent.length
 ? recent.map(item => {
 const role = v16WalletTransactionRole(item);
 const amount = Number(item.amount || 0);
 return `<div class="funds-ledger-row funds-ledger-row--${amount >= 0 ? 'good' : 'bad'}">
 <div><strong>${v16Esc(role.replace(/_/g, ' '))}</strong><span>${v16Esc(v16FormatTs(item.createdAt || 0))}</span></div>
 <div><strong class="${amount >= 0 ? 'good' : 'bad'}">${v16FmtSigned(amount)}</strong><span>${v16Esc(item.asset || metrics.walletSymbol || 'USD')}</span></div>
 </div>`;
 }).join('')
 : `<div class="empty"><div class="ei">--</div><div class="eh">No ${ledgerFilter === 'all' ? 'cash movement' : ledgerFilter} movement loaded</div><div class="es">Delta did not return matching wallet transactions for this profile.</div></div>`;
}

async function renderV16FundsPane(preloaded = null, forceRefresh = false) {
 const pane = document.getElementById('pane-funds');
 if (!pane) return;
 v16ApplyTradingUiPrefs();
 const statusEl = document.getElementById('liveFundsStatus');
 const context = await v16LoadLiveAccountPaneContext(preloaded, forceRefresh);
 if (statusEl) {
 statusEl.textContent = context.statusText;
 statusEl.title = context.statusDetail || context.statusText || '';
 statusEl.className = context.statusClass;
 }
 if (!context.snapshot || !context.metrics) {
 v16UpdateRateLimitBanner(null);
 return;
 }
 v16UpdateRateLimitBanner(context.activeRateLimit, 'Funds');
 v16RenderFunds(context.metrics);
}

async function renderV16OrdersPane(preloaded = null, forceRefresh = false) {
 const pane = document.getElementById('pane-orders');
 if (!pane) return;
 v16ApplyTradingUiPrefs();
 const statusEl = document.getElementById('liveOrdersStatus');
 const context = await v16LoadLiveAccountPaneContext(preloaded, forceRefresh);
 if (statusEl) {
 statusEl.textContent = context.statusText;
 statusEl.className = context.statusClass;
 }
 if (!context.snapshot || !context.metrics) {
 const healthWrap = document.getElementById('liveOrdersHealthBar');
 if (healthWrap) {
 healthWrap.innerHTML = `<div class="empty"><div class="ei">+</div><div class="eh">System health unavailable</div><div class="es">${v16Esc(context.statusText || 'Refresh live data to review engine, profile, slots, and funding feed status.')}</div></div>`;
 }
 v16UpdateRateLimitBanner(null);
 return;
 }
 v16UpdateRateLimitBanner(context.activeRateLimit, 'Orders');
 const { snapshot, metrics } = context;
 await v16RenderOrdersSystemHealthBar(metrics);
 v16RenderPositionProtectionDesk(metrics);
 v16RenderOrderLineage(metrics);
 await v16RenderAutoTradeDecisionAudit(metrics);
 v16RenderExchangeReconciliation(metrics);
 v16RenderNotificationCenter(metrics);
 v16RenderOpenOrders(metrics);
 v16RenderTradeHistory(
 metrics.fills,
 metrics.orderHistory,
 Array.isArray(snapshot?.fills) ? snapshot.fills : [],
 Array.isArray(snapshot?.orderHistory) ? snapshot.orderHistory : []
 );
}

async function openV16LiveTradeOrderPreview(signal = null) {
 if (!signal) return;
 const overlay = document.getElementById('liveOrderOverlay');
 const body = document.getElementById('liveOrderBody');
 const submitBtn = document.getElementById('liveOrderSubmit');
 if (!overlay || !body || !submitBtn) return;
 const previewStore = await storeGet(['autoTradeSettings', V16_SETUP_PERFORMANCE_KEY]);
 const storedSettings = v16LiveAccountView?.autoTradeSettings
 || previewStore?.autoTradeSettings
 || {};
 const autoTradeSettings = sanitizeAutoTradeSettings(storedSettings);
 const previewEntryTrigger = resolveEntryTrigger(signal, autoTradeSettings);
 const previewFamilyKey = String(signal?.setupFamily || signal?.setupFamilyLabel || 'mixed').trim().toLowerCase().replace(/[^a-z0-9]+/g, '_').replace(/^_+|_+$/g, '') || 'mixed';
 const previewSetupEdge = Object.values(previewStore?.[V16_SETUP_PERFORMANCE_KEY]?.rows || {})
 .filter(row => String(row?.familyKey || '').toLowerCase() === previewFamilyKey)
 .sort((a, b) => Number(b?.trades || 0) - Number(a?.trades || 0))[0] || null;
 const reverseSeed = (() => {
 const baseDirection = normalizePositionSide(signal?.direction || signal?.side || '', 'long');
 const explicitExecutionDirection = String(signal?.autoTradeExecutionDirection || '').trim();
 const hasExplicitExecutionDirection = !!explicitExecutionDirection;
 const executionDirection = hasExplicitExecutionDirection
 ? normalizePositionSide(explicitExecutionDirection, baseDirection)
 : (autoTradeSettings?.reverseSignals ? (baseDirection === 'short' ? 'long' : 'short') : baseDirection);
 const nextSignal = {
 ...signal,
 direction: executionDirection,
 side: executionDirection === 'short' ? 'sell' : 'buy',
 autoTradeOriginalDirection: signal?.autoTradeOriginalDirection || baseDirection,
 autoTradeExecutionDirection: executionDirection,
 autoTradeReverseApplied: hasExplicitExecutionDirection
 ? executionDirection !== baseDirection
 : autoTradeSettings?.reverseSignals === true,
 };
 const shouldMirrorTargets = !hasExplicitExecutionDirection && autoTradeSettings?.reverseSignals === true;
 const entryPrice = Number(signal?.entry || signal?.price || 0);
 if (!(entryPrice > 0) || !shouldMirrorTargets) return nextSignal;
 const applyDistance = (distance = 0, kind = 'target') => {
 const safeDistance = Math.abs(Number(distance || 0));
 if (!(safeDistance > 0)) return 0;
 if (kind === 'stop') {
 return executionDirection === 'short'
 ? entryPrice + safeDistance
 : Math.max(0.00000001, entryPrice - safeDistance);
 }
 return executionDirection === 'short'
 ? Math.max(0.00000001, entryPrice - safeDistance)
 : entryPrice + safeDistance;
 };
 const stopDistance = Math.abs(entryPrice - Number(signal?.stopLoss || signal?.sl || 0));
 const tp1Distance = Math.abs(Number(signal?.takeProfit || signal?.tp1 || signal?.tp || 0) - entryPrice);
 const tp2Distance = Math.abs(Number(signal?.takeProfit2 || signal?.tp2 || 0) - entryPrice);
 if (stopDistance > 0) {
 const mirroredStop = applyDistance(stopDistance, 'stop');
 nextSignal.sl = mirroredStop;
 nextSignal.stopLoss = mirroredStop;
 }
 if (tp1Distance > 0) {
 const mirroredTp1 = applyDistance(tp1Distance, 'target');
 nextSignal.tp1 = mirroredTp1;
 nextSignal.tp = mirroredTp1;
 nextSignal.takeProfit = mirroredTp1;
 }
 if (tp2Distance > 0) {
 const mirroredTp2 = applyDistance(tp2Distance, 'target');
 nextSignal.tp2 = mirroredTp2;
 nextSignal.takeProfit2 = mirroredTp2;
 }
 return nextSignal;
 })();
 const orderSignal = {
 symbol: String(reverseSeed.symbol || '').trim().toUpperCase(),
 side: normalizePositionSide(reverseSeed.direction || reverseSeed.side || '', 'long'),
 entry: Number(reverseSeed.entry || reverseSeed.price || 0),
 price: Number(reverseSeed.price || reverseSeed.entry || 0),
 limitPrice: Number(reverseSeed.limitPrice || reverseSeed.price || reverseSeed.entry || 0),
 stopLoss: Math.max(0, Number(reverseSeed.stopLoss || reverseSeed.sl || 0)),
 takeProfit: Math.max(0, Number(reverseSeed.takeProfit || reverseSeed.tp1 || reverseSeed.tp || 0)),
 takeProfit2: Math.max(0, Number(reverseSeed.takeProfit2 || reverseSeed.tp2 || 0)),
 size: Math.max(1, Math.round(Number(reverseSeed.size || reverseSeed.contracts || 1))),
 sizeMode: v16NormalizeLiveOrderSizeMode(reverseSeed.sizeMode || 'usd'),
 orderType: String(reverseSeed.orderType || '').toLowerCase() === 'limit_order' ? 'limit_order' : ((Number(reverseSeed.limitPrice || reverseSeed.price || 0) > 0 && String(reverseSeed.entryMode || '').toLowerCase() !== 'market') ? 'limit_order' : 'market_order'),
 entryMode: String(reverseSeed.entryMode || '').trim().toLowerCase() || (Number(reverseSeed.limitPrice || reverseSeed.price || 0) > 0 ? 'limit' : 'market'),
 baseUrl: v16LiveAccountView.data?.baseUrl || '',
 note: String(reverseSeed.note || '').trim(),
 };
 v16LiveAccountView.orderSignal = orderSignal;
 v16LiveAccountView.protectionOrder = null;
 v16LiveAccountView.activeOpenOrder = null;
 v16LiveAccountView.positionAction = null;
 v16LiveAccountView.preview = null;
 v16LiveAccountView.orderSignalMeta = {
 sizeMode: orderSignal.sizeMode || 'usd',
 definition: await v16EnsureLiveOrderProductDefinition(orderSignal.symbol),
 computedContracts: orderSignal.size,
 markPrice: Number(orderSignal.entry || orderSignal.limitPrice || 0),
 };
 const initialSizeMode = v16NormalizeLiveOrderSizeMode(v16LiveAccountView.orderSignalMeta?.sizeMode || 'usd');
 const titleEl = document.getElementById('liveOrderTitle');
 if (titleEl) titleEl.textContent = 'Live Order Preview';
 const initialSizeValue = v16ComputeLiveOrderInputFromContracts(orderSignal.size, v16LiveAccountView.orderSignalMeta?.sizeMode || 'usd', {
 definition: v16LiveAccountView.orderSignalMeta?.definition || null,
 price: Math.max(0, Number(orderSignal.limitPrice || orderSignal.entry || 0)),
 });
 body.innerHTML = `
 <div class="live-order-preview-grid">
 <label class="account-field"><span>Symbol</span><input class="si" id="liveOrderSymbol" value="${v16Esc(orderSignal.symbol)}"></label>
 <label class="account-field"><span>Side</span><select class="si" id="liveOrderSide"><option value="long" ${orderSignal.side === 'long' ? 'selected' : ''}>Long / Buy</option><option value="short" ${orderSignal.side === 'short' ? 'selected' : ''}>Short / Sell</option></select></label>
 <label class="account-field"><span>Qty Mode</span><select class="si" id="liveOrderQtyMode"><option value="usd" ${initialSizeMode === 'usd' ? 'selected' : ''}>USD</option><option value="contracts" ${initialSizeMode === 'contracts' ? 'selected' : ''}>Lot / Contracts</option><option value="coin" ${initialSizeMode === 'coin' ? 'selected' : ''}>Coin</option></select></label>
 <label class="account-field"><span id="liveOrderSizeLabel">USD Notional</span><input class="si" type="number" id="liveOrderSize" min="0" step="any" value="${v16Esc(String(initialSizeValue))}"></label>
 <label class="account-field"><span>Order Type</span><select class="si" id="liveOrderType"><option value="market_order" ${orderSignal.orderType === 'market_order' ? 'selected' : ''}>Market</option><option value="limit_order" ${orderSignal.orderType === 'limit_order' ? 'selected' : ''}>Limit</option></select></label>
 <label class="account-field"><span>Entry Mode</span><select class="si" id="liveOrderEntryMode"><option value="market" ${orderSignal.entryMode === 'market' ? 'selected' : ''}>Market</option><option value="limit" ${orderSignal.entryMode === 'limit' ? 'selected' : ''}>Limit</option><option value="maker_only" ${orderSignal.entryMode === 'maker_only' ? 'selected' : ''}>Maker Only</option></select></label>
 <label class="account-field"><span>Entry Reference</span><input class="si" type="number" id="liveOrderEntryPrice" min="0" step="any" value="${orderSignal.entry > 0 ? v16Esc(String(orderSignal.entry)) : ''}"></label>
 <label class="account-field"><span>Limit Price</span><input class="si" type="number" id="liveOrderLimitPrice" min="0" step="any" value="${orderSignal.limitPrice > 0 ? v16Esc(String(orderSignal.limitPrice)) : ''}" ${orderSignal.orderType === 'limit_order' ? '' : 'disabled'}></label>
 <label class="account-field"><span>Stop Loss</span><input class="si" type="number" id="liveOrderStopLoss" min="0" step="any" value="${orderSignal.stopLoss > 0 ? v16Esc(String(orderSignal.stopLoss)) : ''}"></label>
 <label class="account-field"><span>TP1 (Full Close)</span><input class="si" type="number" id="liveOrderTakeProfit" min="0" step="any" value="${orderSignal.takeProfit > 0 ? v16Esc(String(orderSignal.takeProfit)) : ''}"></label>
 <label class="account-field"><span>TP2 (Optional 2nd Target)</span><input class="si" type="number" id="liveOrderTakeProfit2" min="0" step="any" value="${orderSignal.takeProfit2 > 0 ? v16Esc(String(orderSignal.takeProfit2)) : ''}"></label>
 </div>
 <div class="live-order-preview-copy">${v16Esc(orderSignal.note || 'Review the FWD TradeDesk Pro live trade preview below before sending the order to the connected exchange.')}</div>
 <div class="account-inline-note ${previewEntryTrigger.passed ? 'good' : 'bad'}">Entry trigger: ${v16Esc(previewEntryTrigger.label || 'Unknown')} - ${v16Esc((previewEntryTrigger.confirmations || previewEntryTrigger.reasons || []).slice(0, 2).join(' | ') || 'Balanced confirm required')}. Setup edge: ${v16Esc(previewSetupEdge?.statusLabel || 'Proving')} (${previewSetupEdge ? `${Number(previewSetupEdge.trades || 0)} sample, expectancy ${Number(previewSetupEdge.expectancy || 0) >= 0 ? '+' : ''}${v16FmtNumber(Number(previewSetupEdge.expectancy || 0), 2)}` : 'no paper/live sample yet'}).</div>
 <div class="live-order-preview-card" id="liveOrderPreviewCard">Preparing live order preview...</div>
 <div class="live-order-preview-card">
 <div class="mo-section">Chart Review</div>
 <div class="live-order-preview-copy">Chart in review panel is back. Use it to inspect the live order context before opening the detached chart.</div>
 <div id="liveOrderChartPreview"></div>
 </div>`;
 overlay.style.display = 'flex';
 v16SyncLiveOrderDeltaButton(orderSignal.symbol);
 submitBtn.textContent = 'Place Live Order';
 submitBtn.disabled = true;
 const syncTypeControls = () => {
 const typeEl = document.getElementById('liveOrderType');
 const modeEl = document.getElementById('liveOrderEntryMode');
 const limitEl = document.getElementById('liveOrderLimitPrice');
 const isLimit = String(typeEl?.value || 'market_order') === 'limit_order';
 if (modeEl) modeEl.value = isLimit ? (modeEl.value === 'maker_only' ? 'maker_only' : 'limit') : 'market';
 if (limitEl) limitEl.disabled = !isLimit;
 };
 const syncQtyMode = () => {
 const nextMode = v16NormalizeLiveOrderSizeMode(document.getElementById('liveOrderQtyMode')?.value || 'usd');
 const prevMode = v16NormalizeLiveOrderSizeMode(v16LiveAccountView.orderSignalMeta?.sizeMode || 'usd');
 const sizeInput = document.getElementById('liveOrderSize');
 if (!sizeInput) return;
 const draft = v16ReadLiveOrderDraftFromForm();
 const pricing = v16ResolveLiveOrderSizingPrice(draft);
 const contracts = v16ComputeLiveOrderContractsFromInput(Number(sizeInput.value || 0), prevMode, {
 definition: v16LiveAccountView.orderSignalMeta?.definition || null,
 price: pricing,
 });
 v16LiveAccountView.orderSignalMeta = {
 ...(v16LiveAccountView.orderSignalMeta || {}),
 sizeMode: nextMode,
 computedContracts: contracts,
 };
 sizeInput.value = String(v16ComputeLiveOrderInputFromContracts(contracts, nextMode, {
 definition: v16LiveAccountView.orderSignalMeta?.definition || null,
 price: pricing,
 }));
 v16SyncLiveOrderQtyInputLabel();
 };
 const refresh = async () => {
 syncTypeControls();
 v16SyncLiveOrderQtyInputLabel();
 await v16RefreshLiveTradeOrderPreview();
 };
 ['liveOrderSymbol', 'liveOrderSide', 'liveOrderSize', 'liveOrderType', 'liveOrderEntryMode', 'liveOrderEntryPrice', 'liveOrderLimitPrice', 'liveOrderStopLoss', 'liveOrderTakeProfit', 'liveOrderTakeProfit2'].forEach(id => {
 const eventName = id === 'liveOrderSide' || id === 'liveOrderType' || id === 'liveOrderEntryMode' ? 'change' : 'input';
 document.getElementById(id)?.addEventListener(eventName, refresh);
 });
 document.getElementById('liveOrderQtyMode')?.addEventListener('change', async () => {
 syncQtyMode();
 await refresh();
 });
 await v16MountLiveOrderPreviewChart({ symbol: orderSignal.symbol, forceRefresh: true });
 await refresh();
}

function v16ResolveAcceptedOrderState(response = {}) {
 const candidates = [
 response?.result?.state,
 response?.result?.order_state,
 response?.result?.orderState,
 response?.result?.status,
 response?.order?.state,
 response?.preview?.state,
 ].map(value => String(value || '').trim().toLowerCase()).filter(Boolean);
 return candidates[0] || '';
}

function v16NotifyOrderConfirmation(title = 'Order placed', message = '') {
 const safeTitle = String(title || 'Order placed');
 const safeMessage = String(message || 'Order request was accepted.');
 globalThis.showSystemToast?.(safeTitle, safeMessage, 'success', 4200);
 try {
 chrome.notifications?.create?.(`fwd-order-${Date.now()}`, {
 type: 'basic',
 iconUrl: 'icons/icon128.png',
 title: safeTitle,
 message: safeMessage,
 priority: 1,
 }, () => void chrome.runtime?.lastError);
 } catch (_) {}
}

function v16NotifyLiveTradeAccepted(draft = {}, response = {}) {
 const symbol = String(draft.symbol || response?.preview?.symbol || '').trim().toUpperCase() || 'Order';
 const side = normalizePositionSide(draft.side || response?.preview?.side || '', 'long') === 'short' ? 'SELL' : 'BUY';
 const size = Math.max(0, Math.round(Number(response?.preview?.size || draft.size || 0)));
 const state = v16ResolveAcceptedOrderState(response);
 const traded = ['filled', 'fully_filled', 'closed', 'complete', 'completed', 'executed'].some(token => state.includes(token));
 const title = traded ? 'Order traded' : 'Order placed';
 const message = `${side} ${symbol}${size > 0 ? ` x ${size}` : ''} ${traded ? 'filled on Delta.' : 'sent to Delta.'}`;
 v16NotifyOrderConfirmation(title, message);
}

async function submitV16LiveOrder() {
 const previewCard = document.getElementById('liveOrderPreviewCard');
 const submitBtn = document.getElementById('liveOrderSubmit');
 if (!previewCard || !submitBtn) return;
 if (v16LiveAccountView.submitInFlight) {
 previewCard.innerHTML = '<div class="account-inline-note warn">Order is already being submitted. Wait for confirmation before pressing Place Order again.</div>';
 return;
 }
 v16LiveAccountView.submitInFlight = true;
 submitBtn.disabled = true;
 previewCard.innerHTML = '<div class="account-inline-note">Submitting request...</div>';
 let response = null;
 try {
 if (v16LiveAccountView.activeOpenOrder) {
 response = await v16RuntimeSend('v16:updateOrder', v16ReadOpenOrderEditDraftFromForm());
 if (!response?.ok) {
 previewCard.innerHTML = `<div class="account-inline-note bad">${v16Esc(response?.error || 'Failed to update order.')}</div>`;
 submitBtn.disabled = false;
 return;
 }
 v16LiveAccountView.lastOrderAction = { type: response.mode === 'cancel_replace' ? 'replaced' : 'updated', symbol: String(v16LiveAccountView.activeOpenOrder.symbol || '').trim().toUpperCase(), at: Date.now() };
 previewCard.innerHTML = `<div class="account-inline-note good">${v16Esc(response.warning || 'Order update sent to Delta.')}</div>`;
 v16NotifyOrderConfirmation('Order updated', `${v16LiveAccountView.lastOrderAction.symbol || 'Order'} update sent to Delta.`);
 } else if (v16LiveAccountView.protectionOrder) {
 response = await v16RuntimeSend('v16:placeProtectionOrder', {
 profileId: getV16ActiveAccountProfile().id,
 ...v16ReadProtectionOrderDraftFromForm(),
 });
 if (!response?.ok) {
 previewCard.innerHTML = `<div class="account-inline-note bad">${v16Esc(response?.error || 'Failed to place protection order.')}</div>`;
 submitBtn.disabled = false;
 return;
 }
 v16LiveAccountView.lastOrderAction = { type: v16LiveAccountView.protectionOrder.kind === 'target' ? 'target-placed' : 'stop-placed', symbol: String(v16LiveAccountView.protectionOrder.symbol || '').trim().toUpperCase(), at: Date.now() };
 previewCard.innerHTML = '<div class="account-inline-note good">Protection order sent to Delta.</div>';
 v16NotifyOrderConfirmation('Protection order placed', `${v16LiveAccountView.lastOrderAction.symbol || 'Order'} protection order sent to Delta.`);
 } else if (v16LiveAccountView.positionAction) {
 const positionActionDraft = document.getElementById('livePositionActionOrderType')
 ? v16ReadPositionActionDraftFromForm()
 : v16LiveAccountView.positionAction;
 v16LiveAccountView.positionAction = positionActionDraft;
 response = await v16RuntimeSend('v16:placePositionAction', {
 profileId: getV16ActiveAccountProfile().id,
 ...positionActionDraft,
 });
 if (!response?.ok) {
 previewCard.innerHTML = `<div class="account-inline-note bad">${v16Esc(response?.error || 'Failed to execute position action.')}</div>`;
 submitBtn.disabled = false;
 return;
 }
 v16LiveAccountView.lastOrderAction = { type: String(v16LiveAccountView.positionAction.requestedAction || 'close'), symbol: String(v16LiveAccountView.positionAction.symbol || '').trim().toUpperCase(), at: Date.now() };
 previewCard.innerHTML = `<div class="account-inline-note good">${v16Esc(response.warning || 'Position action sent to Delta.')}</div>`;
 v16NotifyOrderConfirmation('Position order placed', `${v16LiveAccountView.lastOrderAction.symbol || 'Position'} action sent to Delta.`);
 } else {
 const draft = v16ReadLiveOrderDraftFromForm();
 const profile = getV16ActiveAccountProfile();
 const blockReason = v16ResolveTradeEntryBlockReason({
 symbol: draft.symbol,
 preview: v16LiveAccountView.preview || null,
 profile,
 draft,
 });
 if (blockReason) {
 previewCard.innerHTML = `<div class="account-inline-note bad">${v16Esc(blockReason)}</div>`;
 submitBtn.disabled = false;
 return;
 }
 response = await v16RuntimeSend('v16:placeTradeOrder', {
 profileId: profile.id,
 ...draft,
 });
 if (!response?.ok) {
 previewCard.innerHTML = `<div class="account-inline-note bad">${v16Esc(response?.error || 'Failed to place live order.')}</div>`;
 submitBtn.disabled = false;
 return;
 }
 v16LiveAccountView.lastOrderAction = { type: 'placed', symbol: draft.symbol, at: Date.now() };
 previewCard.innerHTML = '<div class="account-inline-note good">Live order sent to Delta.</div>';
 v16NotifyLiveTradeAccepted(draft, response);
 }
 await renderV16PositionsPane(null, true);
 setTimeout(() => {
 closeV16LiveOrderOverlay();
 }, 400);
 } finally {
 v16LiveAccountView.submitInFlight = false;
 }
}

