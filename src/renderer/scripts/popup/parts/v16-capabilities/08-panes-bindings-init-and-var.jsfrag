 const metrics = v16LiveAccountView?.lastFundsMetrics;
 if (metrics) v16RenderFunds(metrics);
 });
}

async function refreshV16SignalSurfaces() {
 if (typeof renderScanner === 'function') await renderScanner();
 if (typeof renderWatchlist === 'function') await renderWatchlist();
}

async function renderV16All(preloaded = null) {
 await loadV16AccountState();
 await v16RefreshNativeCredentialState();
 const strategyDoc = await storeGet(['strategy']);
 v16LiveAccountView = {
 ...v16LiveAccountView,
 strategy: strategyDoc?.strategy || {},
 };
 const snapshot = await getV16Snapshot(preloaded);
 await Promise.all([
 renderV16CapabilityShell(snapshot),
 renderV16DecisionEngineShell(snapshot),
 ]);
 syncV16SettingsPanelState();
 populateV16ProfileEditor(getV16SelectedAccountProfile());
 renderV16KillSwitchStatus();
 renderV16SecurityStatus();
 renderV16SettingsConnectionCard(snapshot);
 renderV16RiskBridgeBanner();
 await renderV16RiskManageBoard();
 if (document.getElementById('pane-liveanalytics')?.classList.contains('active')) {
 await renderV16LiveAnalyticsPane(snapshot, false);
 }
 if (document.getElementById('pane-positions')?.classList.contains('active')) {
 await renderV16PositionsPane(snapshot, false);
 }
 if (document.getElementById('pane-funds')?.classList.contains('active')) {
 await renderV16FundsPane(snapshot, false);
 }
 if (document.getElementById('pane-orders')?.classList.contains('active')) {
 await renderV16OrdersPane(snapshot, false);
 }
}

function getV16SignalActionState(signal = null) {
 const profile = getV16ActiveAccountProfile();
 const capabilityMeta = getAccountCapabilityMeta(profile.capability);
 const killSwitch = getV16KillSwitchState();
 const hasSecret = hasV16SessionSecret(profile.id);
 const side = normalizePositionSide(signal?.direction || signal?.side || '', 'long');
 const directionLabel = side === 'short' ? 'short' : 'long';
 const previewLabel = killSwitch.enabled
 ? 'Kill switch armed'
 : capabilityMeta.allowsTrade
 ? (hasSecret ? 'Trade-enabled preview' : 'Trade-enabled, no key loaded')
 : capabilityMeta.allowsAccountRead
 ? 'Read-only review'
 : 'Public research';
 return {
 profile,
 capabilityMeta,
 killSwitch,
 hasSecret,
 directionLabel,
 previewLabel,
 canPreviewTrade: capabilityMeta.allowsTrade && !killSwitch.enabled,
 };
}

function buildV16SignalActionMarkup(signal = null) {
 const actionState = getV16SignalActionState(signal);
 return `
 <div class="v16-signal-policy">
 <span class="policy-pill ${actionState.capabilityMeta.tone}">${v16Esc(v16ReadableCapabilityLabel(actionState.capabilityMeta.label))}</span>
 <span class="policy-copy">${v16Esc(actionState.profile.name)} | ${v16Esc(actionState.previewLabel)}</span>
 </div>
 <div class="v16-signal-actions">
 <button class="v16-signal-btn secondary" data-v16-card-action="chart">Open Chart</button>
 <button class="v16-signal-btn primary" data-v16-card-action="review">Review</button>
 <button class="v16-signal-btn secondary" data-v16-card-action="risk">Risk Bridge</button>
 </div>`;
}

function v16ResolveFundingSignalSide(signal = {}, settings = {}) {
 const baseSide = normalizePositionSide(signal?.direction || signal?.side || '', 'long');
 if (signal?.autoTradeExecutionDirection) return normalizePositionSide(signal.autoTradeExecutionDirection, baseSide);
 const reverseApplied = signal?.autoTradeReverseApplied === true || settings?.reverseSignals === true;
 return reverseApplied ? (baseSide === 'short' ? 'long' : 'short') : baseSide;
}

function v16IsFundingAdverseForSignal(signal = {}, threshold = 0, settings = {}) {
 const limit = Math.abs(Number(threshold || 0));
 const rate = Number(signal?.fundingRate || 0);
 const side = v16ResolveFundingSignalSide(signal, settings);
 if (!(limit > 0) || !rate) return false;
 return side === 'short' ? rate <= -limit : rate >= limit;
}

function v16BuildFundingForecast(signal = {}, settings = {}, profile = {}) {
 const rate = Number(signal?.fundingRate || 0);
 const side = v16ResolveFundingSignalSide(signal, settings);
 const notional = Math.max(0, Number(settings?.autoSizeUSD || profile?.maxOrderSizeUSD || 0));
 const intervalSeconds = v16NormalizeFundingIntervalSeconds(signal?.fundingIntervalSeconds || 28800);
 const eventsPerDay = v16FundingEventsPerDay(intervalSeconds);
 const intervalHours = v16FundingIntervalHours(intervalSeconds);
 const exposureFactor = side === 'short' ? rate : -rate;
 const perSettlement = notional > 0 ? (notional * (exposureFactor / 100)) : 0;
 return {
 notional,
 rate,
 intervalSeconds,
 intervalHours,
 eventsPerDay,
 nextFundingAt: Number(signal?.nextFundingAt || 0),
 costSettlement: perSettlement,
 cost24h: perSettlement * eventsPerDay,
 cost48h: perSettlement * eventsPerDay * 2,
 };
}

async function v16BuildSignalDecisionState(signal = {}) {
 const now = Date.now();
 const store = await storeGet([
 'autoTrade',
 'autoTradeSettings',
 'autoTradeCooldowns',
 'autoTradeDecisionAuditV16',
 V16_SETUP_PERFORMANCE_KEY,
 V16_AUTO_TRADE_MANUAL_CONTROLS_KEY,
 ]);
 const profile = getV16ActiveAccountProfile();
 const settings = sanitizeAutoTradeSettings(store?.autoTradeSettings || {});
 const decision = resolveDecisionAction(signal, signal?.activeThresholds || {});
 const entryTrigger = resolveEntryTrigger(signal, settings);
 const riskQuality = resolveRiskQualityGate(signal, settings);
 const symbol = v16NormalizeSymbol(signal?.symbol || '');
 const perfRows = store?.[V16_SETUP_PERFORMANCE_KEY]?.rows || {};
 const familyKey = String(signal?.setupFamily || signal?.setupFamilyLabel || 'mixed').trim().toLowerCase().replace(/[^a-z0-9]+/g, '_').replace(/^_+|_+$/g, '') || 'mixed';
 const setupEdge = Object.values(perfRows)
 .filter(row => String(row?.familyKey || '').toLowerCase() === familyKey)
 .sort((a, b) => Number(b?.trades || 0) - Number(a?.trades || 0))[0] || null;
 const blockedSymbols = new Set(sanitizeBlockedSymbolList(profile?.blockedSymbols || []));
 const manualControls = v16SanitizeManualControls(store?.[V16_AUTO_TRADE_MANUAL_CONTROLS_KEY] || {}, now);
 const manual = v16ResolveManualControlRecord(manualControls, symbol, now);
 const liveMetrics = v16LiveAccountView.lastPositionMetrics || {};
 const slotSummary = v16ResolveConcurrentExposureSummary(liveMetrics);
 const fundingForecast = v16BuildFundingForecast(signal, settings, profile);
 const cooldownTs = Number(store?.autoTradeCooldowns?.[symbol] || 0);
 const cooldownMs = Math.max(0, Number(settings?.cooldownSec || 0) * 1000 - (now - cooldownTs));
 const currentExposureSymbols = new Set([
 ...(Array.isArray(liveMetrics.positions) ? liveMetrics.positions : []).map(position => v16NormalizeSymbol(position?.symbol || '')),
 ...(Array.isArray(liveMetrics.openOrders) ? liveMetrics.openOrders : [])
 .filter(order => !order?.reduceOnly && ['open', 'pending'].includes(String(order?.state || '').toLowerCase()))
 .map(order => v16NormalizeSymbol(order?.symbol || '')),
 ].filter(Boolean));
 const gating = [];
 if (!store?.autoTrade) gating.push('Auto-trade is off');
 if (!getAccountCapabilityMeta(profile?.capability).allowsTrade) gating.push('Active profile is not trade enabled');
 if (getV16KillSwitchState().enabled) gating.push('Kill switch is on');
 if (blockedSymbols.has(symbol)) gating.push('Symbol is blocked in the active profile');
 if (manual.paused) gating.push(`Manual pause active for ${v16FormatDurationShort(Math.max(0, Number(manual.record?.pausedUntil || 0) - now))}`);
 if (manual.reentryBlocked) gating.push(`Re-entry blocked for ${v16FormatDurationShort(Math.max(0, Number(manual.record?.reentryBlockedUntil || 0) - now))}`);
 if (manual.blockedToday) gating.push('Symbol is blocked for the rest of today');
 if (cooldownMs > 0) gating.push(`Cooldown active for ${v16FormatDurationShort(cooldownMs)}`);
 if (decision.action !== 'TRADE NOW') gating.push(v16DescribeDecisionAction(decision.action || 'PASS'));
 if (!(Number(signal?.tradeQuality?.score || 0) >= Number(settings?.minScore || 75))) gating.push(`Trade quality ${Number(signal?.tradeQuality?.score || 0)} is below ${Number(settings?.minScore || 75)}`);
 if (!(signal?.entry && signal?.sl && (signal?.tp1 || signal?.tp))) gating.push('Signal is missing entry, stop, or target');
 if (settings.entryTriggerRequired && !entryTrigger.passed) gating.push(`Entry trigger waiting: ${(entryTrigger.reasons || []).join(', ') || 'confirmation required'}`);
 if (settings.riskQualityRequired && !riskQuality.passed) gating.push(`Risk quality blocked: ${(riskQuality.reasons || []).join(', ') || 'quality gate failed'}`);
 if (!manual.ignoreFunding && v16IsFundingAdverseForSignal(signal, Number(settings?.maxAdverseFundingRatePct || 0), settings)) gating.push('Funding is adverse for the proposed side');
 if (!currentExposureSymbols.has(symbol) && slotSummary.available <= 0) gating.push(`All trade slots are in use (${slotSummary.used}/${slotSummary.maxConcurrent} used)`);
 const eligible = gating.length === 0;
 const statusLabel = eligible
 ? 'Eligible now'
 : decision.action === 'TRADE NOW'
 ? 'Blocked now'
 : 'Setup only';
 const statusTone = eligible ? 'good' : (decision.action === 'TRADE NOW' ? 'bad' : 'warn');
 return {
 symbol,
 profile,
 settings,
 decision,
 manual,
 slotSummary,
 fundingForecast,
 entryTrigger,
 riskQuality,
 setupEdge,
 cooldownMs,
 gating,
 eligible,
 statusLabel,
 statusTone,
 audit: store?.autoTradeDecisionAuditV16 || {},
 };
}

async function v16RunSignalManualControlAction(signal = {}, kind = '') {
 const symbol = v16NormalizeSymbol(signal?.symbol || '');
 if (!symbol) return;
 const durationMs = {
 pause: 6 * 60 * 60 * 1000,
 reentry: 6 * 60 * 60 * 1000,
 ignore_funding: 8 * 60 * 60 * 1000,
 reserve_slot: 6 * 60 * 60 * 1000,
 }[kind] || 0;
 let response;
 if (kind === 'close_block_today') {
 response = await v16RuntimeSend('v16:closeAndBlockSymbolToday', { symbol });
 } else {
 response = await v16RuntimeSend('v16:updateAutoTradeManualControl', {
 symbol,
 kind,
 durationMs,
 });
 }
 if (!response?.ok) throw new Error(response?.error || 'Manual control update failed');
 showSystemToast('Manual control updated', `${symbol} ${kind.replace(/_/g, ' ')} applied.`, 'success', 3200);
 if (document.getElementById('pane-positions')?.classList.contains('active')) await renderV16PositionsPane(null, false);
 if (document.getElementById('pane-orders')?.classList.contains('active')) await renderV16OrdersPane(null, false);
}

async function v16RenderSignalDecisionBlock(signal = {}) {
 const mount = document.getElementById('v16SignalDecisionBlock');
 if (!mount) return;
 const uxHintDismissals = await v16LoadUxHintDismissals();
 const state = await v16BuildSignalDecisionState(signal);
 const systemHealth = await v16BuildSystemHealthModel();
 const followThroughItems = v16BuildDecisionFollowThroughItems(signal, state);
 const actionCards = v16BuildSignalManualActionDefinitions(state);
 const standardActionCards = actionCards.filter(action => !action.destructive);
 const destructiveActionCards = actionCards.filter(action => action.destructive);
 const manualNotes = [
 state.manual.paused ? `Pause until ${v16FormatTs(state.manual.record?.pausedUntil || 0)}` : '',
 state.manual.reentryBlocked ? `Re-entry until ${v16FormatTs(state.manual.record?.reentryBlockedUntil || 0)}` : '',
 state.manual.ignoreFunding ? `Funding override until ${v16FormatTs(state.manual.record?.ignoreFundingUntil || 0)}` : '',
 state.manual.reservedSlot ? `Reserved slot until ${v16FormatTs(state.manual.record?.reservedSlotUntil || 0)}` : '',
 state.manual.blockedToday ? `Blocked until ${v16FormatTs(state.manual.record?.blockedTodayUntil || v16StartOfNextDay())}` : '',
 ].filter(Boolean);
 mount.innerHTML = `
 <div class="mo-decision-shell mo-decision-shell--${v16Esc(state.statusTone)}">
 <div class="mo-decision-top">
 <div>
 <div class="mo-section">What can happen now?</div>
 <div class="mo-decision-status">${v16Esc(state.statusLabel)}</div>
 <div class="mo-decision-copy">${v16Esc(v16BuildDecisionStatusCopy(state))}</div>
 </div>
 <div class="mo-hero-tags">
 <span class="mo-tag ${v16Esc(state.statusTone)}">${v16Esc(state.statusLabel)}</span>
 <span class="mo-tag info">Slots ${state.slotSummary.used}/${state.slotSummary.maxConcurrent}</span>
 <span class="mo-tag ${state.manual.ignoreFunding ? 'warn' : 'info'}">${state.manual.ignoreFunding ? 'Funding override' : 'Funding live'}</span>
 </div>
 </div>
 <div class="live-order-audit-rows live-system-health-strip live-system-health-strip--decision">${v16BuildSystemHealthStripHtml(systemHealth, { compact: true })}</div>
 <div class="mo-decision-grid">
 <div><span>Decision</span><strong>${v16Esc(v16HumanizeDecisionActionLabel(state.decision.action || 'PASS'))}</strong><small>${v16Esc(String(state.decision.setupThreshold || 'threshold'))}</small></div>
 <div><span>Entry Trigger</span><strong class="${state.entryTrigger.passed ? 'good' : 'warn'}">${v16Esc(state.entryTrigger.label || '-')}</strong><small>${v16Esc((state.entryTrigger.confirmations || state.entryTrigger.reasons || []).slice(0, 2).join(' | ') || state.entryTrigger.triggerType || 'Balanced confirm')}</small></div>
 <div><span>Risk Quality</span><strong class="${state.riskQuality.passed ? 'good' : 'bad'}">${v16Esc(state.riskQuality.label || '-')}</strong><small>${v16Esc((state.riskQuality.confirmations || state.riskQuality.reasons || []).slice(0, 2).join(' | ') || `RR ${state.riskQuality.rr || 0}`)}</small></div>
 <div><span>Setup Edge</span><strong class="${v16Esc(state.setupEdge?.tone || 'warn')}">${v16Esc(state.setupEdge?.statusLabel || 'Proving')}</strong><small>${state.setupEdge ? `${Number(state.setupEdge.trades || 0)} sample | Exp ${Number(state.setupEdge.expectancy || 0) >= 0 ? '+' : ''}${v16FmtNumber(Number(state.setupEdge.expectancy || 0), 2)}${state.setupEdge.avgR != null ? ` | Avg ${Number(state.setupEdge.avgR || 0) >= 0 ? '+' : ''}${v16FmtNumber(Number(state.setupEdge.avgR || 0), 2)}R` : ''}` : 'No paper/live sample yet'}</small></div>
 <div><span>Slots</span><strong>${state.slotSummary.used}/${state.slotSummary.maxConcurrent}</strong><small>${state.slotSummary.available} free | ${state.slotSummary.reserved || 0} reserved</small></div>
 <div><span>Funding ${v16FmtNumber(state.fundingForecast.intervalHours, state.fundingForecast.intervalHours % 1 ? 1 : 0)}h</span><strong>${state.fundingForecast.notional > 0 ? v16FmtSigned(state.fundingForecast.costSettlement) : '-'}</strong><small>${state.fundingForecast.rate >= 0 ? '+' : ''}${v16FmtNumber(state.fundingForecast.rate, 4)}% on ~$${v16FmtNumber(state.fundingForecast.notional, 0)}</small></div>
 <div><span>Funding 24h / 48h</span><strong>${state.fundingForecast.notional > 0 ? `${v16FmtSigned(state.fundingForecast.cost24h)} / ${v16FmtSigned(state.fundingForecast.cost48h)}` : '-'}</strong><small>${state.fundingForecast.nextFundingAt ? `Next settlement ${v16FormatTs(state.fundingForecast.nextFundingAt)}` : 'Next funding time unavailable'}</small></div>
 </div>
 <div class="mo-decision-block">
 <div class="v16-section-title"><div class="mo-section">Why ${state.eligible ? 'eligible' : 'blocked'}</div>${v16BuildInlineHelpHtml('Decision blockers', 'This section turns funding, slot, profile, and risk checks into plain language so you can see what is stopping or allowing the trade.')}</div>
 <div class="mo-decision-reasons">${state.gating.length ? state.gating.map(reason => `<div>${v16Esc(reason)}</div>`).join('') : '<div>No active block reason. The system can consider this signal on the next pass.</div>'}</div>
 </div>
 <div class="mo-decision-block">
 <div class="v16-section-title"><div class="mo-section">What override actions are available</div>${v16BuildInlineHelpHtml('Override actions', 'Use these controls only when you want to temporarily change how the engine treats this symbol. Each control is symbol-specific and expires automatically unless cleared first.')}</div>
 ${v16BuildFirstUseHintHtml({
 key: 'decision_overrides',
 title: 'Advanced controls now explain themselves before you use them',
 body: 'Pause, block re-entry, funding override, and slot reservation are all temporary symbol controls. Read the when to use it line first, then apply only the smallest override you need.',
 dismissals: uxHintDismissals,
 tone: 'info',
 })}
 <div class="mo-decision-actions-grid">
 ${standardActionCards.map(action => `
 <div class="mo-decision-action-card ${v16Esc(action.tone || '')}">
 <div class="mo-decision-action-head">
 <button class="mo-action-btn ${v16Esc(action.tone || 'secondary')}" data-v16-manual-kind="${v16Esc(action.kind)}" title="${v16Esc(`${action.when} ${action.effect} ${action.expires}`)}">${v16Esc(action.label)}</button>
 ${v16BuildInlineHelpHtml(action.label, `${action.when} ${action.effect} ${action.expires}`)}
 </div>
 <small class="mo-decision-action-when">${v16Esc(action.when)}</small>
 <small class="mo-decision-action-effect">${v16Esc(action.effect)}</small>
 <small class="mo-decision-action-expiry">${v16Esc(action.expires)}</small>
 </div>
 `).join('')}
 </div>
 ${destructiveActionCards.length ? `<div class="mo-decision-danger-row">
 ${destructiveActionCards.map(action => `
 <div class="mo-decision-action-card ${v16Esc(action.tone || 'danger')}">
 <div class="mo-decision-action-head">
 <button class="mo-action-btn ${v16Esc(action.tone || 'danger')}" data-v16-manual-kind="${v16Esc(action.kind)}" title="${v16Esc(`${action.when} ${action.effect} ${action.expires}`)}">${v16Esc(action.label)}</button>
 ${v16BuildInlineHelpHtml(action.label, `${action.when} ${action.effect} ${action.expires}`)}
 </div>
 <small class="mo-decision-action-when">${v16Esc(action.when)}</small>
 <small class="mo-decision-action-effect">${v16Esc(action.effect)}</small>
 <small class="mo-decision-action-expiry">${v16Esc(action.expires)}</small>
 </div>
 `).join('')}
 </div>` : ''}
 </div>
 <div class="mo-decision-block">
 <div class="v16-section-title"><div class="mo-section">What happens after entry</div>${v16BuildInlineHelpHtml('After entry', 'This is the quick trade story: expected entry, stop, targets, funding estimate, and slot impact after the engine places the trade.')}</div>
 <div class="mo-decision-followup">
 ${followThroughItems.map(item => `<div>${v16Esc(item)}</div>`).join('')}
 </div>
 </div>
 <div class="mo-decision-manual">${manualNotes.length ? manualNotes.map(note => `<span class="mo-tag warn">${v16Esc(note)}</span>`).join('') : '<span class="mo-tag info">No manual symbol overrides active</span>'}</div>
 <div class="mo-decision-footnote">Hover any override for a quick reminder of when to use it, what it changes, and when it expires.</div>
 </div>`;
 v16BindUxHintDismissButtons(mount);
 mount.querySelectorAll('[data-v16-manual-kind]').forEach(button => {
 button.addEventListener('click', async () => {
 button.disabled = true;
 try {
 await v16RunSignalManualControlAction(signal, String(button.dataset.v16ManualKind || ''));
 await v16RenderSignalDecisionBlock(signal);
 } catch (error) {
 reportUiError('Manual control failed', error, { timeoutMs: 5500 });
 } finally {
 button.disabled = false;
 }
 });
 });
}

function activateV16RiskBridge(signal) {
 const entry = Number(signal?.entry || signal?.price || 0);
 const stopLoss = Number(signal?.sl || 0);
 v16SyncRiskCalculatorDefaults({ forceBalance: true, forceRisk: true });
 v16RiskBridge = {
 symbol: String(signal?.symbol || '').toUpperCase(),
 side: normalizePositionSide(signal?.direction || signal?.side || '', 'long'),
 entry,
 stopLoss,
 takeProfit: Number(signal?.tp1 || signal?.tp || 0),
 rr: Number(signal?.rr || 0),
 keyLevels: signal?.keyLevels || null,
 openedAt: Date.now(),
 };
 renderV16RiskBridgeBanner();
 if (typeof calcRisk === 'function') calcRisk();
 return v16RiskBridge;
}

function bindV16StorageListener() {
 if (v16StorageListenerReady || !chrome.storage?.onChanged) return;
 v16StorageListenerReady = true;
 chrome.storage.onChanged.addListener(async (changes, areaName) => {
 const changedKeys = Object.keys(changes || {});
 if (!changedKeys.length) return;
 if (areaName === 'local' && changedKeys.some(key => V16_STORAGE_DEP_KEYS.has(key))) {
 if (changes[V16_ACCOUNT_METADATA_KEY]) {
 await loadV16AccountState(true);
 await refreshV16SignalSurfaces();
 }
 await renderV16All();
 }
 if (areaName === 'session' && changes[V16_ACCOUNT_SECRETS_KEY]) {
 await loadV16AccountState(true);
 await refreshV16SignalSurfaces();
 await renderV16All();
 }
 });
}

async function initV16CapabilityUpgrade() {
 bindV16SettingsUi();
 bindV16StorageListener();
 void (async () => {
 const marker = await storeGet([V16_MANAGE_STORE_CLEANUP_KEY]);
 const lastCleanupAt = Number(marker?.[V16_MANAGE_STORE_CLEANUP_KEY] || 0);
 if (lastCleanupAt && (Date.now() - lastCleanupAt) < V16_MANAGE_STORE_CLEANUP_INTERVAL_MS) return;
 const result = await manageStoreCleanup({
 keepKeys: Object.values(V16_MANAGE_STORE_KEYS),
 maxAgeMs: V16_MANAGE_STORE_MAX_AGE_MS,
 });
 if (result?.ok) await storeSet({ [V16_MANAGE_STORE_CLEANUP_KEY]: Date.now() });
 })().catch(() => {});
 await loadV16AccountState(true);
 await renderV16All();
}

