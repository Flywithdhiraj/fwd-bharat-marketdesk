 if (e.target?.id !== 'btnLiveOrdersToTrade' && !e.target?.closest('#btnLiveOrdersToTrade')) return;
 setWorkspaceGroup?.('trade', true, true);
 setActiveWorkspaceTab?.('scanner', true, true);
 });
 // Delegation: Live Order Close
