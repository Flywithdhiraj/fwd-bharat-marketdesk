 : (value => ({
 defaultPreset: ['clean', 'ema', 'ema_obv', 'key', 'trade', 'decision', 'trend', 'momentum', 'analysis'].includes(String(value?.defaultPreset || '').trim().toLowerCase())
 ? String(value.defaultPreset).trim().toLowerCase()
 : 'key',
 showOrders: !!value?.showOrders,
 showVwap: !!value?.showVwap,
 }));
 const sanitizeKeyLevelSettings = typeof shared.sanitizeKeyLevelSettings === 'function'
 ? shared.sanitizeKeyLevelSettings
 : (value => ({
 pivotLength: Math.max(2, Math.min(20, Math.round(Number(value?.pivotLength || 6) || 6))),
 pivotMemory: Math.max(4, Math.min(200, Math.round(Number(value?.pivotMemory || 50) || 50))),
 numberOfLevels: Math.max(1, Math.min(8, Math.round(Number(value?.numberOfLevels || 4) || 4))),
 displayStrengthAs: String(value?.displayStrengthAs || '').trim().toLowerCase() === 'percent' ? 'percent' : 'count',
 showPivotCircles: value?.showPivotCircles !== false,
 showLevelGlow: value?.showLevelGlow !== false,
 thickness: Math.max(1, Math.min(8, Math.round(Number(value?.thickness || 3) || 3))),
 }));
 const sanitizeChartCacheEnabled = typeof shared.sanitizeChartCacheEnabled === 'function'
 ? shared.sanitizeChartCacheEnabled
 : (value => value !== false);
 const classifyDeltaInstrumentForChart = typeof shared.classifyDeltaInstrument === 'function'
 ? shared.classifyDeltaInstrument
 : (() => ({ assetClass: 'crypto_derivative', assetLabel: 'Crypto', assetBadge: 'Crypto', displayName: '', info: '' }));
 const describeDeltaInstrumentForChart = typeof shared.describeDeltaInstrument === 'function'
 ? shared.describeDeltaInstrument
 : ((symbol, description = '') => String(description || symbol || '').trim());

 const DS_V17_CHART_STATE_KEY = 'dsDetachedChartStateV17';
 const DS_V17_CHART_CACHE_KEY = 'dsChartCacheV17';
 let chartRuntimeCache = {};
 let chartPersistentCacheCleared = false;
 const RESOLUTIONS = Object.freeze(['1m', '5m', '15m', '1h', '4h', '1d', '1w']);
 const RESOLUTION_LABELS = Object.freeze({
