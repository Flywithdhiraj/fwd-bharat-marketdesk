 darvas: false,
 darvasRemoved: false,
 });
 const DARVAS_BOX_DEFAULTS = Object.freeze({
 enabled: false,
 lookback: 0,
 confirmationCandles: 3,
 volumeMultiplier: 1.5,
 atrBreakoutBuffer: 0.10,
 retestAtrTolerance: 0.25,
